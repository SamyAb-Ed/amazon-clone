rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for authentication and validation
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidOrderData() {
      let data = request.resource.data;
      return data.keys().hasAll(['userId', 'userEmail', 'items', 'totalAmount', 'address', 'paymentStatus', 'orderDate']) &&
             data.userId is string &&
             data.userEmail is string &&
             data.items is list &&
             data.totalAmount is number &&
             data.address is map &&
             data.paymentStatus is string &&
             data.orderDate is string;
    }
    
    
    function isValidAddress(address) {
      return address.keys().hasAll(['fullName', 'street', 'city', 'state', 'zipCode', 'country']) &&
             address.fullName is string &&
             address.street is string &&
             address.city is string &&
             address.state is string &&
             address.zipCode is string &&
             address.country is string;
    }
    
    // Orders collection rules
    match /orders/{orderId} {
      // Allow read access only to the order owner
      allow read: if isOwner(resource.data.userId);
      
      // Allow create access only to authenticated users
      // Users can only create orders for themselves
      allow create: if isAuthenticated() && 
                       request.auth.uid == resource.data.userId &&
                       isValidOrderData() &&
                       resource.data.items is list &&
                       resource.data.items.size() > 0 &&
                       resource.data.items.size() <= 50 && // Limit items per order
                       resource.data.totalAmount > 0 &&
                       resource.data.totalAmount <= 100000 && // Maximum order value
                       isValidAddress(resource.data.address) &&
                       resource.data.paymentStatus in ['completed', 'pending', 'failed'] &&
                       resource.data.orderDate is string &&
                       resource.data.orderDate.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}.[0-9]{3}Z$');
      
      // Allow update access only to the order owner
      // Only allow status updates for order management
      allow update: if isOwner(resource.data.userId) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'paymentStatus']) &&
                       request.resource.data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
                       request.resource.data.paymentStatus in ['pending', 'completed', 'failed', 'refunded'];
      
      // Deny delete access - orders should not be deleted
      allow delete: if false;
    }
    
    // Deny access to all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
